<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
  <main class="container">
    <h1>API Test UI</h1>
    <p class="subtitle">NNPTUD-C3 Auth Demo on localhost</p>

    <section class="card">
      <h2>Token</h2>
      <label for="token">Bearer Token</label>
      <textarea id="token" rows="4" placeholder="Token se tu dong luu sau khi login"></textarea>
      <div class="row">
        <button id="save-token" type="button">Luu token</button>
        <button id="clear-token" type="button" class="ghost">Xoa token</button>
      </div>
    </section>

    <section class="card">
      <h2>Login</h2>
      <form id="login-form">
        <label for="username">Username</label>
        <input id="username" name="username" value="student01" required />

        <label for="password">Password</label>
        <input id="password" name="password" type="password" value="Xyz@5678" required />

        <button type="submit">POST /api/v1/auth/login</button>
      </form>
    </section>

    <section class="card">
      <h2>Me</h2>
      <button id="me-btn" type="button">GET /api/v1/auth/me</button>
    </section>

    <section class="card">
      <h2>Change Password</h2>
      <form id="change-form">
        <label for="oldpassword">Old Password</label>
        <input id="oldpassword" name="oldpassword" type="password" value="Xyz@5678" required />

        <label for="newpassword">New Password</label>
        <input id="newpassword" name="newpassword" type="password" value="Abc@1234" required />

        <button type="submit">POST /api/v1/auth/changepassword</button>
      </form>
    </section>

    <section class="card">
      <h2>Response</h2>
      <p id="status"></p>
      <pre id="output">{}</pre>
    </section>
  </main>

  <script>
    (function () {
      var tokenArea = document.getElementById("token");
      var statusEl = document.getElementById("status");
      var outputEl = document.getElementById("output");
      var loginForm = document.getElementById("login-form");
      var changeForm = document.getElementById("change-form");
      var meBtn = document.getElementById("me-btn");
      var saveTokenBtn = document.getElementById("save-token");
      var clearTokenBtn = document.getElementById("clear-token");
      var TOKEN_KEY = "nnptud_auth_token";

      function setToken(token) {
        tokenArea.value = token || "";
        if (token) {
          localStorage.setItem(TOKEN_KEY, token);
        }
      }

      function getToken() {
        return tokenArea.value.trim();
      }

      function render(status, payload) {
        statusEl.textContent = status;
        outputEl.textContent = typeof payload === "string" ? payload : JSON.stringify(payload, null, 2);
      }

      async function callApi(path, method, body, useAuth) {
        var headers = { "Content-Type": "application/json" };
        if (useAuth) {
          var token = getToken();
          if (!token) {
            render("Auth error", "Chua co token. Hay login truoc.");
            return null;
          }
          headers.Authorization = "Bearer " + token;
        }

        var response = await fetch(path, {
          method: method,
          headers: headers,
          body: body ? JSON.stringify(body) : undefined
        });

        var text = await response.text();
        var data = text;
        try {
          data = JSON.parse(text);
        } catch (err) {
          data = text;
        }

        render(response.status + " " + response.statusText, data);
        return { response: response, data: data };
      }

      loginForm.addEventListener("submit", async function (event) {
        event.preventDefault();
        var username = document.getElementById("username").value.trim();
        var password = document.getElementById("password").value;

        var result = await callApi("/api/v1/auth/login", "POST", {
          username: username,
          password: password
        }, false);

        if (result && result.response.ok && typeof result.data === "string") {
          setToken(result.data);
        }
      });

      meBtn.addEventListener("click", async function () {
        await callApi("/api/v1/auth/me", "GET", null, true);
      });

      changeForm.addEventListener("submit", async function (event) {
        event.preventDefault();
        var oldpassword = document.getElementById("oldpassword").value;
        var newpassword = document.getElementById("newpassword").value;

        await callApi("/api/v1/auth/changepassword", "POST", {
          oldpassword: oldpassword,
          newpassword: newpassword
        }, true);
      });

      saveTokenBtn.addEventListener("click", function () {
        setToken(getToken());
        render("Token", "Da luu token vao localStorage");
      });

      clearTokenBtn.addEventListener("click", function () {
        tokenArea.value = "";
        localStorage.removeItem(TOKEN_KEY);
        render("Token", "Da xoa token");
      });

      var savedToken = localStorage.getItem(TOKEN_KEY);
      if (savedToken) {
        tokenArea.value = savedToken;
      }
      render("Ready", "Nhap thong tin roi bam nut de test API.");
    })();
  </script>
</body>
</html>
